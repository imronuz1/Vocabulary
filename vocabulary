<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>SAT Vocab – First 100 Words</title>
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;700;900&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet">
<style>
  :root {
    --bg: #0d0f14;
    --surface: #161920;
    --card: #1e2130;
    --border: #2a2f45;
    --gold: #c9a84c;
    --gold-light: #e8c87a;
    --text: #e8e4d9;
    --muted: #7a7f99;
    --green: #4caf7d;
    --red: #e05c5c;
    --blue: #5b8dee;
  }

  * { box-sizing: border-box; margin: 0; padding: 0; }

  body {
    background: var(--bg);
    color: var(--text);
    font-family: 'DM Sans', sans-serif;
    min-height: 100vh;
    overflow-x: hidden;
  }

  /* ---- background texture ---- */
  body::before {
    content: '';
    position: fixed; inset: 0;
    background:
      radial-gradient(ellipse 60% 40% at 20% 10%, rgba(201,168,76,.07) 0%, transparent 60%),
      radial-gradient(ellipse 50% 50% at 80% 90%, rgba(91,141,238,.06) 0%, transparent 60%);
    pointer-events: none;
  }

  /* ---- header ---- */
  header {
    text-align: center;
    padding: 40px 20px 20px;
  }
  header h1 {
    font-family: 'Playfair Display', serif;
    font-size: clamp(1.8rem, 5vw, 3rem);
    font-weight: 900;
    letter-spacing: -1px;
    background: linear-gradient(135deg, var(--gold) 0%, var(--gold-light) 50%, var(--gold) 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }
  header p { color: var(--muted); margin-top: 6px; font-size: .95rem; }

  /* ---- nav tabs ---- */
  .tabs {
    display: flex; justify-content: center; gap: 8px;
    margin: 24px 20px 0;
    flex-wrap: wrap;
  }
  .tab-btn {
    background: var(--surface);
    border: 1px solid var(--border);
    color: var(--muted);
    padding: 10px 22px;
    border-radius: 50px;
    cursor: pointer;
    font-family: 'DM Sans', sans-serif;
    font-size: .9rem;
    font-weight: 500;
    transition: all .2s;
  }
  .tab-btn.active, .tab-btn:hover {
    background: var(--gold);
    color: #0d0f14;
    border-color: var(--gold);
  }

  /* ---- progress bar ---- */
  .progress-wrap {
    max-width: 640px;
    margin: 20px auto 0;
    padding: 0 20px;
  }
  .progress-info {
    display: flex; justify-content: space-between;
    font-size: .82rem; color: var(--muted); margin-bottom: 6px;
  }
  .progress-track {
    height: 4px;
    background: var(--border);
    border-radius: 4px;
    overflow: hidden;
  }
  .progress-fill {
    height: 100%;
    background: linear-gradient(90deg, var(--gold), var(--gold-light));
    border-radius: 4px;
    transition: width .4s ease;
  }

  /* ---- panels ---- */
  .panel { display: none; padding: 30px 20px 60px; }
  .panel.active { display: block; }

  /* ======== FLASHCARD MODE ======== */
  #flashcard-panel { max-width: 640px; margin: 0 auto; }

  .fc-scene {
    perspective: 1200px;
    height: 320px;
    cursor: pointer;
    margin-bottom: 24px;
  }
  .fc-card {
    width: 100%; height: 100%;
    position: relative;
    transform-style: preserve-3d;
    transition: transform .55s cubic-bezier(.4,0,.2,1);
    border-radius: 20px;
  }
  .fc-card.flipped { transform: rotateY(180deg); }

  .fc-face {
    position: absolute; inset: 0;
    backface-visibility: hidden;
    -webkit-backface-visibility: hidden;
    border-radius: 20px;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 32px;
    text-align: center;
  }
  .fc-front {
    background: var(--card);
    border: 1px solid var(--border);
    box-shadow: 0 20px 60px rgba(0,0,0,.4);
  }
  .fc-back {
    background: linear-gradient(145deg, #1e2540, #1a1e30);
    border: 1px solid #35406a;
    box-shadow: 0 20px 60px rgba(0,0,0,.5);
    transform: rotateY(180deg);
  }

  .fc-num {
    font-size: .75rem;
    color: var(--gold);
    letter-spacing: 2px;
    text-transform: uppercase;
    margin-bottom: 12px;
  }
  .fc-word {
    font-family: 'Playfair Display', serif;
    font-size: clamp(2rem, 7vw, 3.2rem);
    font-weight: 700;
    color: var(--text);
    line-height: 1.1;
  }
  .fc-pos {
    margin-top: 10px;
    font-size: .8rem;
    color: var(--muted);
    background: var(--border);
    padding: 3px 12px;
    border-radius: 50px;
  }
  .fc-tap { margin-top: 20px; font-size: .8rem; color: var(--muted); }
  .fc-tap span { color: var(--gold); }

  .fc-back .fc-def {
    font-size: 1rem;
    line-height: 1.65;
    color: var(--text);
    margin-bottom: 16px;
  }
  .fc-back .fc-example {
    font-style: italic;
    font-size: .88rem;
    color: var(--muted);
    border-left: 3px solid var(--gold);
    padding-left: 12px;
    text-align: left;
    width: 100%;
  }

  .fc-controls {
    display: flex;
    gap: 12px;
    align-items: center;
    justify-content: center;
  }
  .fc-btn {
    background: var(--surface);
    border: 1px solid var(--border);
    color: var(--text);
    padding: 12px 28px;
    border-radius: 50px;
    cursor: pointer;
    font-family: 'DM Sans', sans-serif;
    font-size: .95rem;
    font-weight: 500;
    transition: all .2s;
    display: flex; align-items: center; gap: 8px;
  }
  .fc-btn:hover { border-color: var(--gold); color: var(--gold); }
  .fc-btn.primary {
    background: var(--gold);
    border-color: var(--gold);
    color: #0d0f14;
    font-weight: 600;
  }
  .fc-btn.primary:hover { background: var(--gold-light); }

  .know-btns { display: flex; gap: 12px; margin-top: 16px; justify-content: center; }
  .know-btn {
    flex: 1; max-width: 180px;
    padding: 12px;
    border-radius: 12px;
    border: none;
    cursor: pointer;
    font-family: 'DM Sans', sans-serif;
    font-size: .9rem;
    font-weight: 600;
    transition: all .2s;
  }
  .know-btn.yes { background: rgba(76,175,125,.15); color: var(--green); border: 1px solid rgba(76,175,125,.3); }
  .know-btn.no  { background: rgba(224,92,92,.12);  color: var(--red);   border: 1px solid rgba(224,92,92,.25); }
  .know-btn.yes:hover { background: rgba(76,175,125,.3); }
  .know-btn.no:hover  { background: rgba(224,92,92,.25); }
  .know-btns-label { text-align: center; font-size: .8rem; color: var(--muted); margin-top: 10px; }

  /* ======== QUIZ MODE ======== */
  #quiz-panel { max-width: 640px; margin: 0 auto; }

  .quiz-q {
    background: var(--card);
    border: 1px solid var(--border);
    border-radius: 20px;
    padding: 32px;
    margin-bottom: 20px;
    box-shadow: 0 16px 50px rgba(0,0,0,.35);
  }
  .quiz-label { font-size: .75rem; color: var(--gold); letter-spacing: 2px; text-transform: uppercase; margin-bottom: 12px; }
  .quiz-prompt { font-size: 1.05rem; line-height: 1.6; color: var(--text); }
  .quiz-prompt strong {
    font-family: 'Playfair Display', serif;
    font-size: 1.4rem;
    font-weight: 700;
    color: var(--gold-light);
    display: block;
    margin-top: 8px;
  }

  .quiz-options { display: grid; gap: 10px; }
  .quiz-opt {
    background: var(--surface);
    border: 1.5px solid var(--border);
    color: var(--text);
    padding: 14px 20px;
    border-radius: 12px;
    cursor: pointer;
    font-family: 'DM Sans', sans-serif;
    font-size: .95rem;
    text-align: left;
    transition: all .18s;
    display: flex; align-items: center; gap: 12px;
  }
  .quiz-opt:hover:not(:disabled) { border-color: var(--gold); color: var(--gold); }
  .quiz-opt.correct { border-color: var(--green); background: rgba(76,175,125,.12); color: var(--green); }
  .quiz-opt.wrong   { border-color: var(--red);   background: rgba(224,92,92,.1);   color: var(--red); }
  .quiz-opt:disabled { cursor: default; }

  .opt-letter {
    width: 28px; height: 28px;
    border-radius: 50%;
    background: var(--border);
    display: flex; align-items: center; justify-content: center;
    font-size: .8rem; font-weight: 700;
    flex-shrink: 0;
    transition: all .18s;
  }
  .quiz-opt.correct .opt-letter { background: var(--green); color: #fff; }
  .quiz-opt.wrong   .opt-letter { background: var(--red);   color: #fff; }

  .quiz-feedback {
    margin-top: 16px;
    padding: 14px 18px;
    border-radius: 12px;
    font-size: .9rem;
    line-height: 1.5;
    display: none;
  }
  .quiz-feedback.show { display: block; }
  .quiz-feedback.ok { background: rgba(76,175,125,.1); border: 1px solid rgba(76,175,125,.3); color: var(--green); }
  .quiz-feedback.err { background: rgba(224,92,92,.08); border: 1px solid rgba(224,92,92,.2); color: #f08080; }

  .quiz-next {
    width: 100%;
    background: var(--gold);
    border: none;
    color: #0d0f14;
    padding: 14px;
    border-radius: 12px;
    font-family: 'DM Sans', sans-serif;
    font-size: 1rem;
    font-weight: 700;
    cursor: pointer;
    margin-top: 14px;
    transition: all .2s;
    display: none;
  }
  .quiz-next.show { display: block; }
  .quiz-next:hover { background: var(--gold-light); }

  /* quiz score screen */
  .score-screen {
    text-align: center; padding: 40px 20px;
    display: none;
  }
  .score-screen.show { display: block; }
  .score-ring {
    width: 140px; height: 140px;
    border-radius: 50%;
    background: conic-gradient(var(--gold) calc(var(--pct) * 1%), var(--border) 0%);
    display: flex; align-items: center; justify-content: center;
    margin: 0 auto 24px;
    font-family: 'Playfair Display', serif;
    font-size: 2.2rem;
    font-weight: 900;
    color: var(--gold-light);
    position: relative;
  }
  .score-ring::before {
    content: '';
    position: absolute;
    inset: 12px;
    border-radius: 50%;
    background: var(--bg);
  }
  .score-ring span { position: relative; z-index: 1; }
  .score-screen h2 {
    font-family: 'Playfair Display', serif;
    font-size: 1.8rem; color: var(--text); margin-bottom: 8px;
  }
  .score-screen p { color: var(--muted); margin-bottom: 28px; }

  /* ======== WORD LIST ======== */
  #list-panel { max-width: 760px; margin: 0 auto; }
  .search-bar {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 12px;
    display: flex; align-items: center;
    padding: 0 16px;
    margin-bottom: 20px;
    gap: 10px;
  }
  .search-bar input {
    background: transparent; border: none; outline: none;
    color: var(--text); font-family: 'DM Sans', sans-serif;
    font-size: .95rem; padding: 14px 0; flex: 1;
  }
  .search-bar input::placeholder { color: var(--muted); }
  .search-icon { color: var(--muted); font-size: 1.1rem; }

  .word-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
    gap: 10px;
  }
  .word-card {
    background: var(--card);
    border: 1px solid var(--border);
    border-radius: 12px;
    padding: 14px 16px;
    cursor: pointer;
    transition: all .2s;
  }
  .word-card:hover { border-color: var(--gold); transform: translateY(-2px); }
  .word-card .wc-num { font-size: .72rem; color: var(--gold); font-weight: 600; }
  .word-card .wc-word {
    font-family: 'Playfair Display', serif;
    font-size: 1.15rem; font-weight: 700; margin-top: 2px; color: var(--text);
  }
  .word-card .wc-pos { font-size: .75rem; color: var(--muted); margin-top: 3px; }
  .word-card.known { border-color: rgba(76,175,125,.4); }
  .word-card.known .wc-word { color: var(--green); }

  /* detail modal */
  .modal-overlay {
    position: fixed; inset: 0;
    background: rgba(0,0,0,.75);
    display: flex; align-items: center; justify-content: center;
    z-index: 100;
    padding: 20px;
    display: none;
  }
  .modal-overlay.show { display: flex; }
  .modal {
    background: var(--card);
    border: 1px solid var(--border);
    border-radius: 20px;
    max-width: 520px; width: 100%;
    padding: 32px;
    position: relative;
    max-height: 80vh;
    overflow-y: auto;
  }
  .modal-close {
    position: absolute; top: 16px; right: 16px;
    background: var(--border); border: none; color: var(--text);
    width: 32px; height: 32px; border-radius: 50%;
    cursor: pointer; font-size: 1.1rem;
    display: flex; align-items: center; justify-content: center;
    transition: background .2s;
  }
  .modal-close:hover { background: var(--muted); }
  .modal h2 {
    font-family: 'Playfair Display', serif;
    font-size: 2rem; color: var(--gold-light); margin-bottom: 4px;
  }
  .modal .m-pos { color: var(--muted); font-size: .85rem; margin-bottom: 20px; }
  .modal .m-def { margin-bottom: 16px; }
  .modal .m-def-num { font-size: .75rem; color: var(--gold); font-weight: 600; margin-bottom: 4px; text-transform: uppercase; letter-spacing: 1px; }
  .modal .m-def-text { font-size: .95rem; line-height: 1.6; }
  .modal .m-example { font-style: italic; color: var(--muted); font-size: .88rem; margin-top: 6px; }

  /* stats bar */
  .stats-row {
    display: flex; gap: 16px; justify-content: center;
    margin: 0 20px 24px; flex-wrap: wrap;
  }
  .stat-chip {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 50px;
    padding: 8px 18px;
    font-size: .85rem;
    display: flex; align-items: center; gap: 8px;
  }
  .stat-chip .dot {
    width: 8px; height: 8px;
    border-radius: 50%;
  }

  /* keyboard hint */
  .kbd-hint {
    text-align: center; font-size: .78rem; color: var(--muted);
    margin-top: 14px;
  }
  .kbd { background: var(--border); padding: 2px 7px; border-radius: 4px; font-family: monospace; }
</style>
</head>
<body>

<header>
  <h1>SAT Vocabulary · First 100</h1>
  <p>by Farangiz Murodiy — master every word before test day</p>
</header>

<div class="stats-row">
  <div class="stat-chip"><span class="dot" style="background:var(--gold)"></span><span id="stat-total">100 words</span></div>
  <div class="stat-chip"><span class="dot" style="background:var(--green)"></span><span id="stat-known">0 known</span></div>
  <div class="stat-chip"><span class="dot" style="background:var(--blue)"></span><span id="stat-quiz">0 quizzed</span></div>
</div>

<div class="tabs">
  <button class="tab-btn active" onclick="switchTab('flashcard')">📇 Flashcards</button>
  <button class="tab-btn" onclick="switchTab('quiz')">🧠 Quiz</button>
  <button class="tab-btn" onclick="switchTab('list')">📋 Word List</button>
</div>

<!-- FLASHCARD PANEL -->
<div class="panel active" id="flashcard-panel">
  <div class="progress-wrap">
    <div class="progress-info">
      <span id="fc-counter">1 / 100</span>
      <span id="fc-pct">0%</span>
    </div>
    <div class="progress-track"><div class="progress-fill" id="fc-bar" style="width:1%"></div></div>
  </div>

  <div style="max-width:640px;margin:24px auto 0">
    <div class="fc-scene" onclick="flipCard()">
      <div class="fc-card" id="fc-card">
        <div class="fc-face fc-front">
          <div class="fc-num" id="fc-num">WORD 01</div>
          <div class="fc-word" id="fc-word">Demand</div>
          <div class="fc-pos" id="fc-pos">verb / noun</div>
          <div class="fc-tap">tap to reveal → <span>definition</span></div>
        </div>
        <div class="fc-face fc-back">
          <div class="fc-def" id="fc-def">To ask for something forcefully, claiming a right to it.</div>
          <div class="fc-example" id="fc-example">She demanded a refund for the faulty product.</div>
        </div>
      </div>
    </div>

    <div class="fc-controls">
      <button class="fc-btn" onclick="navigate(-1)">← Prev</button>
      <button class="fc-btn primary" onclick="flipCard()">Flip</button>
      <button class="fc-btn" onclick="navigate(1)">Next →</button>
    </div>
    <p class="kbd-hint"><kbd class="kbd">←</kbd> prev &nbsp;·&nbsp; <kbd class="kbd">Space</kbd> flip &nbsp;·&nbsp; <kbd class="kbd">→</kbd> next</p>

    <div class="know-btns-label">Did you know this word?</div>
    <div class="know-btns">
      <button class="know-btn no" onclick="markKnown(false)">✗ Still Learning</button>
      <button class="know-btn yes" onclick="markKnown(true)">✓ I Know It</button>
    </div>
  </div>
</div>

<!-- QUIZ PANEL -->
<div class="panel" id="quiz-panel">
  <div class="progress-wrap">
    <div class="progress-info">
      <span id="q-counter">Question 1 / 100</span>
      <span id="q-score">Score: 0</span>
    </div>
    <div class="progress-track"><div class="progress-fill" id="q-bar" style="width:1%"></div></div>
  </div>

  <div style="max-width:640px;margin:20px auto 0">
    <div id="quiz-main">
      <div class="quiz-q">
        <div class="quiz-label" id="q-label">Definition → Word</div>
        <div class="quiz-prompt" id="q-prompt">Loading…</div>
      </div>
      <div class="quiz-options" id="q-opts"></div>
      <div class="quiz-feedback" id="q-feedback"></div>
      <button class="quiz-next" id="q-next" onclick="nextQuestion()">Next Question →</button>
    </div>
    <div class="score-screen" id="score-screen">
      <div class="score-ring" id="score-ring" style="--pct:0"><span id="score-pct">0%</span></div>
      <h2 id="score-title">Quiz Complete!</h2>
      <p id="score-msg"></p>
      <button class="fc-btn primary" onclick="restartQuiz()" style="margin:0 auto">🔄 Retake Quiz</button>
    </div>
  </div>
</div>

<!-- LIST PANEL -->
<div class="panel" id="list-panel">
  <div class="search-bar">
    <span class="search-icon">🔍</span>
    <input type="text" id="search-input" placeholder="Search words…" oninput="filterWords()">
  </div>
  <div class="word-grid" id="word-grid"></div>
</div>

<!-- DETAIL MODAL -->
<div class="modal-overlay" id="modal" onclick="closeModal(event)">
  <div class="modal">
    <button class="modal-close" onclick="document.getElementById('modal').classList.remove('show')">✕</button>
    <h2 id="m-word"></h2>
    <div class="m-pos" id="m-pos"></div>
    <div id="m-defs"></div>
  </div>
</div>

<script>
// ===================== DATA =====================
const WORDS = [
  { word:"Demand", pos:"verb / noun", defs:["To ask for something forcefully, claiming a right to it or expressing a need for it.","The desire or need for something, accompanied by willingness to pay for it."], ex:["She demanded a refund for the faulty product.","There is a high demand for organic food."] },
  { word:"Speculate", pos:"verb", defs:["To consider or discuss something based on incomplete or uncertain evidence.","To engage in investment or financial trading with the hope of profit but risk of loss."], ex:["Journalists speculated about the election outcome.","Some investors speculate on the stock market."] },
  { word:"Doubt", pos:"verb / noun", defs:["To feel uncertain or unsure about something or someone.","A feeling of uncertainty or lack of conviction."], ex:["I doubt whether he will arrive on time.","She always had a nagging doubt about her abilities."] },
  { word:"Establish", pos:"verb", defs:["To set up or create something, typically an organization, system, or rule.","To prove or demonstrate something to be true or valid."], ex:["The government established a committee to investigate.","The study establishes a link between smoking and cancer."] },
  { word:"Impartial", pos:"adjective", defs:["Treating all people and groups equally, without bias or favoritism.","Not influenced by personal feelings, opinions, or prejudices."], ex:["The judge was praised for being impartial.","The journalist strived for impartial reporting."] },
  { word:"Offhand", pos:"adverb / adjective", defs:["Without previous thought or preparation; casually.","Showing a casual or indifferent attitude; lacking consideration."], ex:["He answered the question offhand without references.","Her offhand remarks offended some audience members."] },
  { word:"Persistent", pos:"adjective", defs:["Continuing to exist or endure despite obstacles or setbacks.","Determined or tenacious in achieving a goal; not giving up easily."], ex:["The persistent rain caused flooding.","The persistent student mastered the subject."] },
  { word:"Mandatory", pos:"adjective", defs:["Required by law or rules; obligatory.","Necessary or essential."], ex:["Wearing a seatbelt is mandatory while driving.","Attendance at the meeting is mandatory."] },
  { word:"Circumvent", pos:"verb", defs:["To find a way to avoid or bypass something, especially a rule or restriction.","To overcome or defeat an obstacle cleverly."], ex:["They found a loophole to circumvent tax regulations.","Her agility helped her circumvent the opponent's defense."] },
  { word:"Eclipse", pos:"noun / verb", defs:["An event in which one celestial object passes in front of another, blocking its light.","To overshadow or surpass something in importance or fame."], ex:["The solar eclipse drew crowds of spectators.","The new superstar eclipsed the previous record holder."] },
  { word:"Fabricate", pos:"verb", defs:["To invent or create something, typically with deceitful intent.","To construct or manufacture something using various materials."], ex:["The witness admitted to fabricating the story.","The carpenter fabricated a beautiful wooden table."] },
  { word:"Exemplify", pos:"verb", defs:["To serve as an example of something or to illustrate a particular quality."], ex:["The entrepreneur exemplifies dedication and hard work."] },
  { word:"Discernible", pos:"adjective", defs:["Able to be perceived, recognized, or understood with effort.","Clear or distinguishable."], ex:["There was a discernible outline of a figure in the distance.","The difference in quality was discernible even to an untrained eye."] },
  { word:"Straightforward", pos:"adjective", defs:["Simple, clear, and easy to understand or follow.","Direct and honest in behavior or communication."], ex:["The assembly instructions were straightforward.","I appreciate her straightforward approach to problem-solving."] },
  { word:"Inconclusive", pos:"adjective", defs:["Not providing a definite or decisive result or outcome.","Not leading to a resolution or decision."], ex:["The experiment yielded inconclusive results.","The meeting ended inconclusively with no consensus."] },
  { word:"Unbiased", pos:"adjective", defs:["Not having preconceived opinions; fair and impartial.","Not influenced by personal feelings or external factors."], ex:["The journalist reported the news in an unbiased manner.","The study used unbiased data collection methods."] },

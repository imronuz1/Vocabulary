// ===================== STATE =====================
let fcIndex = 0;
let fcFlipped = false;
let known = new Set();
let quizIndex = 0;
let quizScore = 0;
let quizOrder = [];
let answered = false;
let quizTotal = 0;

// ===================== UTILS =====================
function shuffle(arr) {
  const a = [...arr];
  for (let i = a.length-1; i>0; i--) {
    const j = Math.floor(Math.random()*(i+1));
    [a[i],a[j]] = [a[j],a[i]];
  }
  return a;
}

function updateStats() {
  document.getElementById('stat-known').textContent = known.size + ' known';
  document.getElementById('stat-quiz').textContent = quizTotal + ' quizzed';
}

// ===================== TABS =====================
function switchTab(name) {
  document.querySelectorAll('.panel').forEach(p => p.classList.remove('active'));
  document.querySelectorAll('.tab-btn').forEach(b => b.classList.remove('active'));
  document.getElementById(name+'-panel').classList.add('active');
  event.target.classList.add('active');
  if (name === 'list') renderList();
  if (name === 'quiz' && quizOrder.length === 0) startQuiz();
}

// ===================== FLASHCARDS =====================
function renderFC() {
  const w = WORDS[fcIndex];
  document.getElementById('fc-num').textContent = `WORD ${String(fcIndex+1).padStart(2,'0')}`;
  document.getElementById('fc-word').textContent = w.word;
  document.getElementById('fc-pos').textContent = w.pos;
  document.getElementById('fc-def').textContent = w.defs[0];
  document.getElementById('fc-example').textContent = '"' + w.ex[0] + '"';
  document.getElementById('fc-counter').textContent = `${fcIndex+1} / 100`;
  const pct = Math.round(((fcIndex+1)/100)*100);
  document.getElementById('fc-pct').textContent = pct + '%';
  document.getElementById('fc-bar').style.width = pct + '%';
  // reset flip
  if (fcFlipped) {
    document.getElementById('fc-card').classList.remove('flipped');
    fcFlipped = false;
  }
}

function flipCard() {
  fcFlipped = !fcFlipped;
  document.getElementById('fc-card').classList.toggle('flipped', fcFlipped);
}

function navigate(dir) {
  fcIndex = (fcIndex + dir + 100) % 100;
  renderFC();
}

function markKnown(yes) {
  if (yes) known.add(fcIndex);
  else known.delete(fcIndex);
  updateStats();
  navigate(1);
}

// ===================== QUIZ =====================
function startQuiz() {
  quizOrder = shuffle([...Array(100).keys()]);
  quizIndex = 0;
  quizScore = 0;
  answered = false;
  document.getElementById('quiz-main').style.display = 'block';
  document.getElementById('score-screen').classList.remove('show');
  renderQuestion();
}

function renderQuestion() {
  if (quizIndex >= quizOrder.length) { showScore(); return; }
  answered = false;
  const wi = quizOrder[quizIndex];
  const w = WORDS[wi];
  const isDefToWord = Math.random() > 0.5;

  document.getElementById('q-counter').textContent = `Question ${quizIndex+1} / 100`;
  document.getElementById('q-score').textContent = `Score: ${quizScore}`;
  const pct = Math.round(((quizIndex)/100)*100);
  document.getElementById('q-bar').style.width = Math.max(pct,1) + '%';
  document.getElementById('q-feedback').classList.remove('show','ok','err');
  document.getElementById('q-next').classList.remove('show');

  let prompt, label;
  if (isDefToWord) {
    label = 'Definition → Word';
    prompt = `<strong>Which word matches this definition?</strong><br>"${w.defs[0]}"`;
  } else {
    label = 'Word → Definition';
    prompt = `What does this word mean?<strong>${w.word}</strong>`;
  }
  document.getElementById('q-label').textContent = label;
  document.getElementById('q-prompt').innerHTML = prompt;

  // build 4 options
  let wrong = shuffle([...Array(100).keys()].filter(i=>i!==wi)).slice(0,3);
  let opts = shuffle([wi, ...wrong]);
  const letters = ['A','B','C','D'];
  const container = document.getElementById('q-opts');
  container.innerHTML = '';
  opts.forEach((oi, idx) => {
    const btn = document.createElement('button');
    btn.className = 'quiz-opt';
    const optWord = WORDS[oi];
    btn.innerHTML = `<span class="opt-letter">${letters[idx]}</span>${isDefToWord ? optWord.word : optWord.defs[0]}`;
    btn.onclick = () => checkAnswer(oi, wi, btn, isDefToWord);
    container.appendChild(btn);
  });
}

function checkAnswer(chosen, correct, btn, isDefToWord) {
  if (answered) return;
  answered = true;
  quizTotal++;
  const allBtns = document.querySelectorAll('.quiz-opt');
  allBtns.forEach(b => b.disabled = true);

  const isCorrect = chosen === correct;
  if (isCorrect) {
    btn.classList.add('correct');
    quizScore++;
  } else {
    btn.classList.add('wrong');
    // highlight correct
    allBtns.forEach(b => {
      const txt = b.innerText.slice(1).trim();
      const cw = WORDS[correct];
      if (isDefToWord && txt === cw.word) b.classList.add('correct');
      if (!isDefToWord && txt === cw.defs[0]) b.classList.add('correct');
    });
  }

  const fb = document.getElementById('q-feedback');
  fb.classList.add('show', isCorrect ? 'ok' : 'err');
  fb.textContent = isCorrect
    ? `✓ Correct! "${WORDS[correct].word}" — ${WORDS[correct].defs[0]}`
    : `✗ The correct answer was: "${WORDS[correct].word}" — ${WORDS[correct].defs[0]}`;

  document.getElementById('q-next').classList.add('show');
  document.getElementById('q-score').textContent = `Score: ${quizScore}`;
  updateStats();
}

function nextQuestion() {
  quizIndex++;
  renderQuestion();
}

function showScore() {
  document.getElementById('quiz-main').style.display = 'none';
  const sc = document.getElementById('score-screen');
  sc.classList.add('show');
  const pct = Math.round((quizScore/100)*100);
  document.getElementById('score-ring').style.setProperty('--pct', pct);
  document.getElementById('score-pct').textContent = pct + '%';
  document.getElementById('q-bar').style.width = '100%';
  const msgs = [
    [90, "Outstanding! You're SAT-ready! 🏆"],
    [70, "Great job! A bit more review and you'll ace it! 💪"],
    [50, "Good effort. Keep practicing! 📚"],
    [0, "Keep going — repetition is the key to mastery! 🔄"]
  ];
  const [,msg] = msgs.find(([t]) => pct >= t);
  document.getElementById('score-title').textContent = `${quizScore} / 100 Correct`;
  document.getElementById('score-msg').textContent = msg;
}

function restartQuiz() {
  startQuiz();
}

// ===================== WORD LIST =====================
function renderList(filter='') {
  const grid = document.getElementById('word-grid');
  grid.innerHTML = '';
  const q = filter.toLowerCase();
  WORDS.forEach((w, i) => {
    if (q && !w.word.toLowerCase().includes(q) && !w.defs[0].toLowerCase().includes(q)) return;
    const card = document.createElement('div');
    card.className = 'word-card' + (known.has(i) ? ' known' : '');
    card.innerHTML = `<div class="wc-num">#${String(i+1).padStart(2,'0')}</div>
      <div class="wc-word">${w.word}</div>
      <div class="wc-pos">${w.pos}</div>`;
    card.onclick = () => openModal(i);
    grid.appendChild(card);
  });
}

function filterWords() {
  renderList(document.getElementById('search-input').value);
}

function openModal(i) {
  const w = WORDS[i];
  document.getElementById('m-word').textContent = w.word;
  document.getElementById('m-pos').textContent = w.pos;
  let html = '';
  w.defs.forEach((d, di) => {
    html += `<div class="m-def">
      <div class="m-def-num">Definition ${di+1}</div>
      <div class="m-def-text">${d}</div>
      ${w.ex[di] ? `<div class="m-example">"${w.ex[di]}"</div>` : ''}
    </div>`;
  });
  document.getElementById('m-defs').innerHTML = html;
  document.getElementById('modal').classList.add('show');
}

function closeModal(e) {
  if (e.target === document.getElementById('modal')) {
    document.getElementById('modal').classList.remove('show');
  }
}

// ===================== KEYBOARD =====================
document.addEventListener('keydown', e => {
  const fc = document.getElementById('flashcard-panel');
  if (!fc.classList.contains('active')) return;
  if (e.key === 'ArrowRight') navigate(1);
  if (e.key === 'ArrowLeft') navigate(-1);
  if (e.key === ' ') { e.preventDefault(); flipCard(); }
});

// ===================== INIT =====================
renderFC();
updateStats();
</script>
